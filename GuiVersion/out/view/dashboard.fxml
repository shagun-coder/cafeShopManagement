<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">
    
    <left>
        <VBox prefWidth="230.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" prefHeight="120.0" spacing="5.0" style="-fx-padding: 10;">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="☕ COFFEE HOUSE" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #A98467;" text="Management System" />
                </VBox>
                
                <VBox spacing="8.0" style="-fx-padding: 15;">
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleDashboardNav" styleClass="menu-btn" text="📊 Dashboard" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleProductsNav" styleClass="menu-btn-active" text="📦 Products" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleOrdersNav" styleClass="menu-btn" text="🛒 Orders" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleCustomersNav" styleClass="menu-btn" text="👥 Customers" />
                </VBox>
                
                <AnchorPane VBox.vgrow="ALWAYS" />
                
                <VBox style="-fx-padding: 15;">
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleLogout" styleClass="btn-logout" text="🚪 Logout" />
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <AnchorPane style="-fx-background-color: #FDFBF7;" BorderPane.alignment="CENTER">
            <children>
                
                <VBox fx:id="productsForm" spacing="20.0" style="-fx-padding: 25;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3D2314;" text="📋 Product Information" />
                        
                        <GridPane hgap="25.0" styleClass="form-container" vgap="15.0">
                            <children>
                                <Label text="Product ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="prodIdField" promptText="e.g. 101" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                
                                <Label text="Product Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="prodNameField" promptText="Cappuccino" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                
                                <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <ComboBox fx:id="categoryBox" maxWidth="1.7976931348623157E308" promptText="Choose Category" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Coffee" />
                                            <String fx:value="Beverage" />
                                            <String fx:value="Food" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                
                                <Label text="Price (₹):" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                <TextField fx:id="priceField" promptText="150.00" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                                
                                <Label text="Quantity:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                <TextField fx:id="quantityField" promptText="20" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                                
                                <Label text="Status:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                <ComboBox fx:id="statusBox" maxWidth="1.7976931348623157E308" promptText="Choose Status" GridPane.columnIndex="3" GridPane.rowIndex="2">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Available" />
                                            <String fx:value="Unavailable" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </children>
                        </GridPane>

                        <HBox spacing="15.0">
                            <children>
                                <Button onAction="#handleAddProduct" prefHeight="38.0" prefWidth="110.0" styleClass="btn-add" text="➕ ADD" />
                                <Button onAction="#handleUpdateProduct" prefHeight="38.0" prefWidth="110.0" styleClass="btn-update" text="📝 UPDATE" />
                                <Button onAction="#handleDeleteProduct" prefHeight="38.0" prefWidth="110.0" styleClass="btn-delete" text="🗑️ DELETE" />
                                <Button onAction="#handleClearFields" prefHeight="38.0" prefWidth="110.0" styleClass="btn-clear" text="🔄 CLEAR" />
                            </children>
                        </HBox>
                        
                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3D2314;" text="📋 Product List View" />
                                <TableView fx:id="productTable" onMouseClicked="#handleTableClick" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="85.0" text="ID" />
                                        <TableColumn fx:id="colName" prefWidth="200.0" text="Product Name" />
                                        <TableColumn fx:id="colCategory" prefWidth="130.0" text="Category" />
                                        <TableColumn fx:id="colPrice" prefWidth="110.0" text="Price (₹)" />
                                        <TableColumn fx:id="colQuantity" prefWidth="110.0" text="Quantity" />
                                        <TableColumn fx:id="colStatus" prefWidth="130.0" text="Status" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
                
                <VBox fx:id="otherViewsForm" alignment="CENTER" spacing="10.0" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label fx:id="otherViewLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #7F5539;" text="Dashboard View Screen" />
                        <Label text="Data display module integration ongoing..." style="-fx-text-fill: gray;" />
                    </children>
                </VBox>

            </children>
        </AnchorPane>
    </center>
</BorderPane>